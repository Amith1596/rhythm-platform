# Rhythm Platform - Environment Variables
# Copy this file to .env and fill in your actual keys

# Required for AI Expert Finder feature
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required to fetch real GitHub repository data
# Get from: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_TOKEN=your_github_personal_access_token_here

# Django Secret Key (auto-generated, keep this secret)
SECRET_KEY=django-insecure-change-this-in-production

# Database (SQLite by default, change for production)
# DATABASE_URL=postgresql://user:password@localhost/rhythm

# Debug mode (set to False in production)
DEBUG=True
